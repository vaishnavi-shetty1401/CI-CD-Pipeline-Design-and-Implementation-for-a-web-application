pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo '🔹 Checking out code from GitHub...'
                checkout scm
            }
        }

        stage('Build') {
            steps {
                echo '🔹 Building application...'
                sh 'echo Build completed'
            }
        }

        stage('Test') {
            steps {
                echo '🔹 Running tests...'
                sh 'echo Tests completed'
            }
        }

        stage('Code Quality') {
            steps {
                echo '🔹 Running SonarQube placeholder...'
                sh 'echo SonarQube completed'
            }
        }

        stage('Docker Placeholder') {
            steps {
                echo '🔹 Docker build simulation completed'
            }
        }

        stage('Security Scan Placeholder') {
            steps {
                echo '🔹 Trivy security scan simulation completed'
            }
        }

        stage('Deployment Placeholder') {
            steps {
                echo '🔹 Kubernetes deployment simulation completed'
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline SUCCESS'
        }

        failure {
            echo '❌ Pipeline FAILED'
        }
    }
}